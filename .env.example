# Telegram bot token from @BotFather
P2P_BOT_TOKEN=123456:ABC-your-token

# Comma-separated Telegram user IDs of the admins (get yours from @userinfobot)
P2P_ADMIN_IDS=111111111,222222222

# Optional: a private admin group chat ID where orders are posted.
# Leave unset to DM each admin instead. (Group IDs are negative, e.g. -1001234567890)
#P2P_ADMIN_CHAT_ID=-1001234567890

# SQLite database file
P2P_DB_PATH=p2p.sqlite3

# Per-order USD bounds
P2P_MIN_USD=10
P2P_MAX_USD=10000

# Payout promise shown to users after their deposit is confirmed
P2P_ETA_TEXT=15-30 minutes

# TRON auto-scan: how often to poll TronGrid for deposits (seconds),
# and how long an unpaid order waits for its deposit before expiring (minutes)
P2P_SCAN_INTERVAL_SEC=10
P2P_DEPOSIT_TTL_MIN=60
# Remind the user if they haven't deposited this many minutes after ordering
P2P_REMIND_MIN=5

# Max simultaneously-open orders per user
P2P_OPEN_ORDERS_MAX=3

# Optional TronGrid API key (free at trongrid.io) for higher rate limits
#P2P_TRONGRID_KEY=your-key

# Your support username (with @), shown on Support / Buy buttons
P2P_SUPPORT_HANDLE=@your_support

# ── Web admin panel (optional) ──────────────────────────────────────────────
# Leave the password blank to keep the panel OFF (Telegram admin still works).
# When set, the panel can change rates, deposit address, support, admin IDs and
# the bot token — so use a strong password, keep the bind on localhost, and put
# nginx + HTTPS in front. NEVER expose the raw port to the internet.
P2P_PANEL_PASSWORD=
# Cookie-signing secret (auto-generated & stored in the DB if left blank)
P2P_PANEL_SECRET=
# 127.0.0.1 = localhost only (use with nginx or an SSH tunnel).
# 0.0.0.0   = reachable at http(s)://<server-ip>:<port>  (lock it with a firewall!)
P2P_PANEL_HOST=127.0.0.1
P2P_PANEL_PORT=8088
# Serve the panel over HTTPS directly (recommended when host=0.0.0.0 without nginx).
# A self-signed cert is fine — see DEPLOY.md for the one-line openssl command.
P2P_PANEL_TLS_CERT=
P2P_PANEL_TLS_KEY=
