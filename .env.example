# Telegram bot token from @BotFather
P2P_BOT_TOKEN=123456:ABC-your-token

# Comma-separated Telegram user IDs of the admins (get yours from @userinfobot)
P2P_ADMIN_IDS=111111111,222222222

# Optional: a private admin group chat ID where orders are posted.
# Leave unset to DM each admin instead. (Group IDs are negative, e.g. -1001234567890)
#P2P_ADMIN_CHAT_ID=-1001234567890

# SQLite database file
P2P_DB_PATH=p2p.sqlite3

# Per-order USD bounds
P2P_MIN_USD=10
P2P_MAX_USD=10000

# Seconds after submitting during which the user can cancel the order
P2P_CANCEL_WINDOW_SEC=30

# Payout promise shown to users after they send USDT
P2P_ETA_TEXT=15-30 minutes

# Your support username (with @), shown on Support / Buy buttons
P2P_SUPPORT_HANDLE=@your_support
